{
  "name": "wbauth",
  "version": "0.1.0",
  "description": "Web Bot Auth (RFC 9421) TypeScript SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "web-bot-auth": "^0.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^6",
    "vitest": "^4"
  }
}
